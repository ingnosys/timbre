# ============================================================
# TIMBRE QR — CONFIGURACIÓN
# Copiá este archivo como ".env" y completá los valores
# ============================================================

# --- WHATSAPP (CallMeBot - 100% gratis) ---
# Cómo activar (una sola vez):
#   1. Guardá el número +34 644 60 49 16 en tus contactos como "CallMeBot"
#   2. Enviá por WhatsApp el mensaje exacto: I allow callmebot to send me messages
#   3. En minutos CallMeBot te responde con tu API key
#
# Tu número de teléfono SIN el + (Argentina: 549 + número sin el 0 inicial)
# Ejemplo: si tu celular es 011 1234-5678 → ponés 5491112345678
WHATSAPP_PHONE=549XXXXXXXXXX

# API key que te envió CallMeBot por WhatsApp:
WHATSAPP_APIKEY=REEMPLAZAR_CON_TU_APIKEY

# --- COORDENADAS DE TU PUERTA ---
# Para obtenerlas: abrí Google Maps → clic derecho sobre tu puerta → copiá las coordenadas
# Ejemplo Buenos Aires: -34.6037, -58.3816
HOUSE_LAT=-34.6037
HOUSE_LNG=-58.3816

# Radio máximo permitido en METROS (100 = 100 metros alrededor de tu puerta)
ALLOWED_RADIUS_METERS=100

# --- SERVIDOR ---
PORT=3000

# URL pública del servidor (con ngrok sería algo como: https://abc123.ngrok-free.app)
# Para prueba local podés poner: http://localhost:3000
SERVER_URL=http://localhost:3000

# --- PERSONALIZACIÓN ---
# Nombre que aparece en la página del visitante y en las notificaciones
HOME_NAME=Mi Casa
