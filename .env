# ============================================================
# TIMBRE QR — CONFIGURACIÓN
# Editá estos valores con los tuyos y guardá el archivo
# ============================================================

# --- TELEGRAM ---
# 1. Abrí Telegram y buscá @BotFather
# 2. Enviá /newbot y seguí los pasos
# 3. Pegá el token aquí:
TELEGRAM_BOT_TOKEN=REEMPLAZAR_CON_TU_TOKEN

# 4. Buscá @userinfobot en Telegram, enviá cualquier mensaje
# 5. Pegá el "Id" que te responde aquí:
TELEGRAM_CHAT_ID=REEMPLAZAR_CON_TU_CHAT_ID

# --- WHATSAPP (CallMeBot) ---
# 1. Agrega el número +34 644 60 49 16 a tus contactos.
# 2. Envíale un mensaje que diga: "I allow callmebot to send me messages"
# 3. Te responderá con tu API Key. Completa los valores abajo:
WHATSAPP_PHONE=REEMPLAZAR_CON_TU_TELEFONO_EJ_5492215555555
WHATSAPP_APIKEY=REEMPLAZAR_CON_TU_APIKEY

# --- COORDENADAS DE TU PUERTA ---
# Abrí Google Maps → clic derecho sobre tu puerta → clic en las coordenadas para copiar
HOUSE_LAT=-34.913245
HOUSE_LNG=-57.976003

# Máxima distancia permitida en metros (recomendado: 50-100)
ALLOWED_RADIUS_METERS=50

# --- SERVIDOR ---
PORT=3000

# URL pública (cambiá esto cuando uses ngrok o un hosting)
# Si usás ngrok: https://abc123.ngrok-free.app
# Si usás Railway: https://timbre-qr-production.up.railway.app
SERVER_URL=https://timbre-mizv.onrender.com

# --- PERSONALIZACIÓN ---
HOME_NAME=35 Nro 1130 1/2 Depto. 4
