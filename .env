# ============================================================
# TIMBRE QR — CONFIGURACIÓN
# Editá estos valores con los tuyos y guardá el archivo
# ============================================================

# --- TELEGRAM ---
# 1. Abrí Telegram y buscá @BotFather
# 2. Enviá /newbot y seguí los pasos
# 3. Pegá el token aquí:
TELEGRAM_BOT_TOKEN=REEMPLAZAR_CON_TU_TOKEN

# 4. Buscá @userinfobot en Telegram, enviá cualquier mensaje
# 5. Pegá el "Id" que te responde aquí:
TELEGRAM_CHAT_ID=REEMPLAZAR_CON_TU_CHAT_ID


# --- SERVIDOR ---
PORT=3000

# URL pública (cambiá esto cuando uses ngrok o un hosting)
# Si usás ngrok: https://abc123.ngrok-free.app
# Si usás Railway: https://timbre-qr-production.up.railway.app
SERVER_URL=https://timbre-mizv.onrender.com

# --- PERSONALIZACIÓN ---
HOME_NAME=Mi Casa
