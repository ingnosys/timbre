# ============================================================
# TIMBRE QR — CONFIGURACIÓN
# Editá estos valores con los tuyos y guardá el archivo
# ============================================================

# --- COORDENADAS DE TU PUERTA ---
# Abrí Google Maps → clic derecho sobre tu puerta → clic en las coordenadas para copiar
HOUSE_LAT=-34.9132165
HOUSE_LNG=-57.9760482

# Máxima distancia permitida en metros (recomendado: 50-100)
ALLOWED_RADIUS_METERS=10

# --- WHATSAPP (CallMeBot - GRATIS) ---
# Cómo activar:
#   1. Guardá el número +34 644 60 49 16 en tus contactos como "CallMeBot"
#   2. Enviá por WhatsApp el mensaje exacto: I allow callmebot to send me messages
#   3. En minutos CallMeBot te responde con tu API key
#
# Número de teléfono SIN el + (ej: Argentina 549 + número sin el 0)
WHATSAPP_PHONE=5492215456981
# API key que te envió CallMeBot:
WHATSAPP_APIKEY=6435685

# --- SERVIDOR ---
PORT=3000

# URL pública (cambiá esto cuando uses ngrok o un hosting)
# Si usás ngrok: https://abc123.ngrok-free.app
# Si usás Railway: https://timbre-qr-production.up.railway.app
SERVER_URL=https://timbre-mizv.onrender.com

# --- PERSONALIZACIÓN ---
HOME_NAME=Deto 4
